# ─── AWS ──────────────────────────────────────────────────────────────────────
# IAM credentials with EC2 + SSM permissions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# EC2 instance ID to control (e.g. i-0abc123def456)
INSTANCE_ID=

# AWS region
AWS_REGION=ap-south-1

# ─── Discord OAuth ─────────────────────────────────────────────────────────────
# From https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of your deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── Discord Audit Webhook ─────────────────────────────────────────
# Send infrastructure events to a Discord channel.
DISCORD_WEBHOOK_URL=
